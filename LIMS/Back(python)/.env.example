# AnythingLLM配置
ANYTHINGLLM_BASE_URL=http://localhost:3001
ANYTHINGLLM_WORKSPACE_ID=YOUR_WORKSPACE_ID_HERE
ANYTHINGLLM_API_KEY=YOUR_API_KEY_HERE

# ⚠️ 使用说明：
# 1. 复制此文件为 .env
# 2. 将 YOUR_WORKSPACE_ID_HERE 替换为你的实际 Workspace ID
# 3. 将 YOUR_API_KEY_HERE 替换为你的实际 API Key
#
# ⚠️ 重要提示：
# - 此文件包含敏感信息，已被 .gitignore 保护
# - 不要将此文件提交到版本控制系统
# - 每个开发者需要使用自己的配置
