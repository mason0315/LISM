<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.bookmanagement.mapper.CommentMapper">
    <resultMap id="Base_Comment_List" type="com.upc.bookmanagement.entity.Comment">
        <id property="commentId" column="comment_id"/>
        <result property="title" column="title"/>
        <result property="username" column="username"/>
        <result property="comment" column="comment"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="getCommentsByTitle" resultMap="Base_Comment_List">
        SELECT * FROM comments WHERE title = #{title} ORDER BY created_at DESC
    </select>
</mapper> 