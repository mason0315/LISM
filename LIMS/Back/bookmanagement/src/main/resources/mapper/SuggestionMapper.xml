<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.upc.bookmanagement.mapper.SuggestionMapper">

    <resultMap id="Suggestion_List" type="com.upc.bookmanagement.entity.Suggestion">
        <id property="id" column="id" />
        <result property="userId" column="user_id" />
        <result property="content" column="content" />
        <result property="createdAt" column="created_at" />
    </resultMap>

    <sql id="Base_colum">
        id,user_id,content,created_at
    </sql>

    <select id="getAllSuggestions" resultMap="Suggestion_List">
        select <include refid="Base_colum"/>
        from suggestion
    </select>

    <select id="getSuggestionsByUserId" resultMap="Suggestion_List">
        select <include refid="Base_colum"/>
        from suggestion
        where user_id = #{userId}
    </select>

</mapper>